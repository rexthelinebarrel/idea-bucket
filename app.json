{
  "expo": {
    "name": "灵感桶",
    "slug": "idea-bucket",
    "owner": "nachdenken",
    "version": "0.10.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ideabucket",
    "userInterfaceStyle": "dark",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/65173909-5ce6-413f-a828-97925e43737b",
      "checkAutomatically": "NEVER"
    },
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "com.rexthelinebarrel.ideabucket",
      "adaptiveIcon": {
        "backgroundColor": "#080A0E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.REQUEST_INSTALL_PACKAGES"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#080A0E",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "允许灵感桶使用麦克风录制语音灵感。"
        }
      ],
      [
        "@jamsch/expo-speech-recognition",
        {
          "microphonePermission": "允许灵感桶使用麦克风录制语音灵感。",
          "speechRecognitionPermission": "允许灵感桶使用语音识别，把语音转成文字。",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "65173909-5ce6-413f-a828-97925e43737b"
      }
    }
  }
}
